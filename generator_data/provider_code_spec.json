							"description": "Free-form labels (e.g. project:odyssey, env:build) used for grouping in the monthly usage report. Set at VM create only — values must be non-empty strings up to 128 chars."
						}
					},
					{
						"name": "user_data",
						"single_nested": {
							"computed_optional_required": "computed_optional",
							"attributes": [
								{
									"name": "data",
									"string": {
										"computed_optional_required": "required",
										"description": "Cloud-init user-data passed to the VM on first boot, in a format supported by cloud-init (e.g. a #cloud-config document or a shell script). May be base64-encoded when is_base64 is true. See the cloud-init supported user-data formats: https://docs.cloud-init.io/en/latest/explanation/format/index.html. Note: if provided, user-data overwrites the auto-generated cloud-init configuration which is responsible for configuring ssh-keys and the default username, for example. To ensure access, those must be configured by the provided user-data. Example configurations: https://docs.cloud-init.io/en/latest/reference/examples.html#yaml-examples. Length must be between 1 and 64000 characters.",
										"validators": [
											{
												"custom": {
													"imports": [
														{
															"path": "github.com/hashicorp/terraform-plugin-framework-validators/stringvalidator"
														}
													],
													"schema_definition": "stringvalidator.LengthBetween(1, 64000)"
												}
											}
										]
									}
								},
								{
									"name": "is_base64",
									"bool": {
										"computed_optional_required": "computed_optional",
										"default": {
											"static": false
										},
										"description": "Whether data is base64-encoded. Use this for binary user-data that cannot be encoded as JSON, such as gzip-compressed cloud-init content (e.g. https://docs.cloud-init.io/en/latest/explanation/format/gzip.html#gzip). Default is false."
									}
								}
							],
							"description": "Cloud-init user-data to pass to the VM on first boot. Exactly one of ssh_keys or user_data must be specified: a request that sets both, or neither, is rejected with a 422."
						}
					},
